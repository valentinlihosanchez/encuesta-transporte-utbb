# ===== Servidor =====
PORT=3000
NODE_ENV=development

# ===== Base de datos PostgreSQL =====
# Si usas docker-compose.yml de este repo, estos valores ya coinciden.
# Si usas un PostgreSQL local, ajusta usuario/contraseña/host segun tu instalacion.
DATABASE_URL=postgres://utbb:utbb@localhost:5432/encuesta_transporte

# Alternativa por variables sueltas (se usan si DATABASE_URL no esta definida)
PGHOST=localhost
PGPORT=5432
PGUSER=utbb
PGPASSWORD=utbb
PGDATABASE=encuesta_transporte

# ===== Sesion del panel admin =====
# Cadena larga y aleatoria. Genera una con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ===== Admin inicial (usado por: npm run seed:admin) =====
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-contrasena

# ===== Rate limiting del envio de encuesta (anti-bot) =====
# Generoso porque en el wifi del campus muchos estudiantes comparten una IP (NAT).
RATE_WINDOW_MS=900000
RATE_MAX_ENVIOS=40

# ===== Mapas =====
# Este proyecto usa Leaflet + OpenStreetMap (tiles) + Nominatim (geocoding), que NO requieren API key.
# Si decidieras migrar a Google Maps por mejor precision de direcciones, define aqui tu llave:
# GOOGLE_MAPS_API_KEY=
